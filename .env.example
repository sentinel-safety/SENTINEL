# SENTINEL environment template

# --- Core ---------------------------------------------------------------
SENTINEL_ENV=dev
SENTINEL_LOG_LEVEL=INFO
SENTINEL_SERVICE_NAME=sentinel

# --- Data stores --------------------------------------------------------
# sentinel_app — runtime role (limited privileges, respects RLS); used by services.
# sentinel    — owner/DDL role; used by Alembic migrations only.
SENTINEL_POSTGRES_DSN=postgresql+asyncpg://sentinel_app:sentinel_app_dev@127.0.0.1:5432/sentinel  # pragma: allowlist secret
SENTINEL_POSTGRES_SYNC_DSN=postgresql+psycopg://sentinel:sentinel_dev@127.0.0.1:5432/sentinel  # pragma: allowlist secret
SENTINEL_REDIS_DSN=redis://127.0.0.1:6379/0
SENTINEL_QDRANT_URL=http://127.0.0.1:6333

# --- Database tuning ----------------------------------------------------
SENTINEL_DB_POOL_SIZE=10
SENTINEL_DB_MAX_OVERFLOW=20
SENTINEL_DB_STATEMENT_TIMEOUT_MS=5000

# --- Observability ------------------------------------------------------
SENTINEL_OTLP_ENDPOINT=http://127.0.0.1:4317

# --- LLM providers ------------------------------------------------------
# Leave unset in dev — the `fake` provider is the default and does not
# make network calls. Real keys are loaded from the secret store in
# non-dev environments; never paste a production key into `.env`.
SENTINEL_PREPROCESS_BASE_URL=http://127.0.0.1:8002
SENTINEL_CLASSIFIER_FIRST_PASS_BASE_URL=http://127.0.0.1:8003
SENTINEL_SCORING_BASE_URL=http://127.0.0.1:8004
SENTINEL_PATTERNS_BASE_URL=http://127.0.0.1:8005
SENTINEL_MEMORY_BASE_URL=http://127.0.0.1:8001
SENTINEL_MEMORY_LOOKBACK_DAYS=21
SENTINEL_GRAPH_BASE_URL=http://127.0.0.1:8006
SENTINEL_GRAPH_LOOKBACK_DAYS=7
SENTINEL_QDRANT_FINGERPRINT_COLLECTION=actor_fingerprints
SENTINEL_FINGERPRINT_VECTOR_DIM=16
SENTINEL_FINGERPRINT_SIMILARITY_THRESHOLD=0.85
SENTINEL_CLUSTER_MIN_FLAGGED_NEIGHBORS=2
SENTINEL_FINGERPRINT_SEARCH_TOP_K=10

SENTINEL_PATTERNS_LLM_QUEUE_NAME=patterns:llm-queue

SENTINEL_LLM_DEFAULT_PROVIDER=fake
SENTINEL_LLM_TIMEOUT_SECONDS=5.0
# SENTINEL_ANTHROPIC_API_KEY=
# SENTINEL_OPENAI_API_KEY=

# --- Response engine ----------------------------------------------------
SENTINEL_RESPONSE_BASE_URL=http://127.0.0.1:8007
SENTINEL_RESPONSE_TIER_CHANGE_STREAM=response:tier_changes
SENTINEL_RESPONSE_RETRY_STREAM=response:retry_queue
SENTINEL_RESPONSE_DEAD_LETTER_STREAM=response:dead_letter
SENTINEL_RESPONSE_RETRY_MAX_ATTEMPTS=5
SENTINEL_RESPONSE_RETRY_BASE_DELAY_SECONDS=2.0
SENTINEL_RESPONSE_RETRY_MAX_DELAY_SECONDS=60.0
SENTINEL_RESPONSE_HMAC_TIMESTAMP_SKEW_SECONDS=300
SENTINEL_RESPONSE_WORKER_BLOCK_MS=2000

# --- Explainability ----------------------------------------------------
SENTINEL_REASONING_RETENTION_DAYS=90

# --- Dashboard BFF -----------------------------------------------------
SENTINEL_DASHBOARD_BFF_BASE_URL=http://127.0.0.1:8009
# Leave both unset in dev — an ephemeral RSA keypair is generated at
# load time. Provide these in staging/prod from the secret store.
# SENTINEL_DASHBOARD_JWT_PRIVATE_KEY_PEM=
# SENTINEL_DASHBOARD_JWT_PUBLIC_KEY_PEM=
SENTINEL_DASHBOARD_ACCESS_TOKEN_TTL_MINUTES=30
SENTINEL_DASHBOARD_REFRESH_TOKEN_TTL_DAYS=14
SENTINEL_DASHBOARD_ARGON2_TIME_COST=3
SENTINEL_DASHBOARD_ARGON2_MEMORY_COST=65536
SENTINEL_DASHBOARD_ARGON2_PARALLELISM=1

# --- Honeypot -------------------------------------------------
SENTINEL_HONEYPOT_BASE_URL=http://127.0.0.1:8010
SENTINEL_HONEYPOT_PERSONAS_DIR=services/honeypot/personas  # relative to repo root (Docker WORKDIR /app)
SENTINEL_HONEYPOT_TIER_THRESHOLD=4
SENTINEL_HONEYPOT_JURISDICTION_ALLOWLIST=

# --- Federation ----------------------------------------------
SENTINEL_FEDERATION_ENABLED_GLOBALLY=false
SENTINEL_FEDERATION_SIGNALS_STREAM=federation:signals
SENTINEL_FEDERATION_QDRANT_COLLECTION=federated_fingerprints
SENTINEL_FEDERATION_PUBLISH_TIER_THRESHOLD=restrict
SENTINEL_FEDERATION_ADVISORY_DELTA=10
SENTINEL_FEDERATION_LOW_REPUTATION_DELTA=3
SENTINEL_FEDERATION_LOW_REPUTATION_THRESHOLD=30
SENTINEL_FEDERATION_BASE_URL=http://127.0.0.1:8011
SENTINEL_FEDERATION_CONSUMER_BLOCK_MS=2000

# --- Synthetic Data -----------------------------------------
SENTINEL_SYNTHETIC_BASE_URL=http://127.0.0.1:8012
SENTINEL_SYNTHETIC_RESEARCHER_TOKEN_TTL_MINUTES=60
SENTINEL_SYNTHETIC_DEFAULT_SEED=424242
