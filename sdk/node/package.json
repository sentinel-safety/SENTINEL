{
  "name": "@sentinel/client",
  "version": "0.1.0",
  "description": "Official Node.js/TypeScript SDK for SENTINEL behavioral intelligence API.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
