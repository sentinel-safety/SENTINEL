{
  "name": "@sentinel-safety/client",
  "version": "1.0.0",
  "description": "Official Node.js/TypeScript SDK for SENTINEL behavioral intelligence API.",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pack": "npm run build && npm pack",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "child-safety",
    "grooming-detection",
    "behavioral-analysis",
    "trust-safety",
    "content-moderation",
    "online-safety"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sentinel-safety/SENTINEL"
  },
  "homepage": "https://github.com/sentinel-safety/SENTINEL#readme",
  "bugs": {
    "url": "https://github.com/sentinel-safety/SENTINEL/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.4"
  }
}
